rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - bio: string (optional)
    //   - styles: list (optional)
    //   - level: string (optional)
    //   - role: string (optional)
    //   - location: map (optional)
    //
    // Collection: schools
    // Fields:
    //   - name: string (required)
    //   - address: string (required)
    //   - location: map (required)
    //   - description: string (optional)
    //   - website: string (optional)
    //   - styles: list (optional)
    //
    // Collection: events
    // Fields:
    //   - title: string (required)
    //   - description: string (optional)
    //   - date: timestamp (required)
    //   - location: map (required)
    //   - address: string (required)
    //   - type: string (required)
    //   - organizerId: string (required)
    //   - price: number (optional)
    //
    // Collection: bookings
    // Fields:
    //   - eventId: string (required)
    //   - userId: string (required)
    //   - timestamp: timestamp (required)
    //   - status: string (required)
    //
    // Collection: chats/{roomId}/messages
    // Fields:
    //   - senderId: string (required)
    //   - text: string (required)
    //   - timestamp: timestamp (required)
    //   - roomId: string (required)

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() < 100 &&
             (!('bio' in data) || (data.bio is string && data.bio.size() < 500));
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'date', 'location', 'organizerId']) &&
             data.title is string && data.title.size() < 200 &&
             data.date is timestamp &&
             data.location is map &&
             data.organizerId is string;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['eventId', 'userId', 'timestamp', 'status']) &&
             data.eventId is string &&
             data.userId == request.auth.uid &&
             data.timestamp is timestamp &&
             data.status in ['Confirmed', 'Cancelled'];
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'text', 'timestamp', 'roomId']) &&
             data.senderId == request.auth.uid &&
             data.text is string && data.text.size() < 1000 &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /schools/{schoolId} {
      allow read: if true;
      allow write: if isAuthenticated(); // In a real app, only admins
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidEvent(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.organizerId) && isValidEvent(request.resource.data);
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.organizerId);
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || request.auth.uid == get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizerId);
      allow create: if isAuthenticated() && isValidBooking(request.resource.data);
      allow update: if isAuthenticated() && isOwner(resource.data.userId) && isValidBooking(request.resource.data);
    }

    match /chats/{roomId}/messages/{messageId} {
      allow read: if isAuthenticated(); // Could be restricted to event participants
      allow create: if isAuthenticated() && isValidMessage(request.resource.data);
    }
  }
}
